# PostgreSQL connection string used by Prisma (matches docker-compose defaults)
DATABASE_URL="postgresql://shortener:shortener@localhost:5432/shortener"

# Redis connection string for the redirect cache and the sliding-window rate limiter (matches docker-compose)
REDIS_URL="redis://localhost:6379"

# Secret used to sign JWT session cookies — generate one with: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-string"

# Salt mixed into the SHA-256 IP hashes used for unique-visitor counting — generate with: openssl rand -hex 16
IP_HASH_SALT="replace-with-another-random-string"

# Public origin used to build short URLs and QR code contents
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# IP geolocation provider for click analytics: "ip-api" (free, no key required) or "none" to disable
GEO_PROVIDER="ip-api"

# Max link creations allowed per IP per minute (sliding window)
RATE_LIMIT_CREATE_PER_MIN="10"

# Max redirects served per IP per minute (sliding window)
RATE_LIMIT_REDIRECT_PER_MIN="120"

# Seconds a resolved slug stays in the Redis redirect cache (capped by the link's expiry)
LINK_CACHE_TTL_SECONDS="3600"
